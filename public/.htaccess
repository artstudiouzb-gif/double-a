<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Исполняемые .php — только точки входа приложения. Любой другой прямой
    # запрос к .php (например, файл в /uploads) получает 403 ещё до
    # фронт-контроллера. Реализовано rewrite-правилом, а не «Require all
    # denied + точечное разрешение»: та схема ломалась на LiteSpeed и части
    # shared-хостингов (слияние Require-секций отличается от Apache 2.4),
    # отдавая 403 даже index.php. Внутренние переписывания не задеваются:
    # проверяется исходный REQUEST_URI, а не переписанный путь.
    RewriteCond %{REQUEST_URI} \.php$ [NC]
    RewriteCond %{REQUEST_URI} !(^|/)(index|download)\.php$ [NC]
    RewriteRule .* - [F]

    # Существующие файлы и папки (assets, uploads) отдаются напрямую
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Всё остальное — через единую точку входа
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Долгий кэш для версионированных ассетов (задача 127). URL меняется через
    # ?v=<hash> при обновлении файла (App\Core\Asset::url), поэтому CDN отдаёт
    # новую версию без ручной очистки, а старые кэшируются «навсегда».
    <FilesMatch "\.(css|js|woff2?|ttf|eot|svg|jpe?g|png|gif|webp|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

Options -Indexes
DirectoryIndex index.php

# Сжатие текстовых ответов. Brotli предпочтительнее; на серверах без него
# автоматически используется gzip/DEFLATE. Бинарные изображения не трогаем.
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/xml
    AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json application/xml application/rss+xml image/svg+xml
</IfModule>
<IfModule !mod_brotli.c>
    <IfModule mod_deflate.c>
        AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
        AddOutputFilterByType DEFLATE application/javascript application/json application/xml application/rss+xml image/svg+xml
    </IfModule>
</IfModule>

# Fallback: без mod_rewrite фронт-контроллер не работает, поэтому запрещаем
# все .php с точечным разрешением точек входа (историческая схема; на
# конфигурациях без mod_rewrite слияние Require обычно каноничное).
<IfModule !mod_rewrite.c>
    <IfModule mod_authz_core.c>
        <FilesMatch "\.php$">
            Require all denied
        </FilesMatch>
        <Files "index.php">
            Require all granted
        </Files>
        <Files "download.php">
            Require all granted
        </Files>
    </IfModule>
    <IfModule !mod_authz_core.c>
        <Files "index.php">
            Order allow,deny
            Allow from all
        </Files>
        <Files "download.php">
            Order allow,deny
            Allow from all
        </Files>
    </IfModule>
</IfModule>
